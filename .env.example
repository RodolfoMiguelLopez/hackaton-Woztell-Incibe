# Copia este fichero como .env y rellena los valores reales
# NUNCA subas .env a git

# OpenAI
OPENAI_API_KEY=sk-proj-...

# Woztell WhatsApp API
WOZTELL_ACCESS_TOKEN=eyJ...
WOZTELL_CHANNEL_ID=your-channel-id

# Teléfonos (formato internacional sin +, ej: 34612345678)
TELEFONO_USUARIO=34XXXXXXXXX
TELEFONO_FAMILIAR=34XXXXXXXXX

# Nombres
NOMBRE_USUARIO=Antonio
NOMBRE_FAMILIAR=María

# URL pública de la app (Railway u otro hosting)
BASE_URL=https://your-app.up.railway.app

# Poner true para usar modo mock sin llamar a OpenAI (tests locales)
USE_MOCK_AI=false
